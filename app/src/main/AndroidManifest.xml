<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Overlay of TYPE_APPLICATION_OVERLAY for the selection UI (constitution VI) -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- Foreground service hosting the single-frame MediaProjection capture (constitution X) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />

    <!-- Talking to the user's own BYOK AI endpoint (constitution IX) -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name=".CircleSearchApplication"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:theme="@style/Theme.CircleSearch">

        <activity
            android:name=".ui.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Contract: specs/001-visual-search-assistant/contracts/trigger-intent-contract.md (T009) -->
        <activity
            android:name=".ui.trigger.TriggerEntryActivity"
            android:exported="true"
            android:excludeFromRecents="true"
            android:launchMode="singleTask"
            android:noHistory="true"
            android:theme="@style/Theme.CircleSearch.Transparent">
            <intent-filter>
                <action android:name="com.circulesearch.app.action.START_VISUAL_SEARCH" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <activity
            android:name=".data.capture.MediaProjectionConsentActivity"
            android:exported="false"
            android:theme="@style/Theme.CircleSearch.Transparent" />

        <service
            android:name=".data.capture.ScreenCaptureForegroundService"
            android:exported="false"
            android:foregroundServiceType="mediaProjection" />

        <service
            android:name=".data.accessibility.TriggerAccessibilityService"
            android:exported="true"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

    </application>

</manifest>
