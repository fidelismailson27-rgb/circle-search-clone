<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Overlay of TYPE_APPLICATION_OVERLAY for the selection UI (constitution VI) -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- Foreground service hosting the single-frame MediaProjection capture (constitution X) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />

    <!-- Talking to the user's own BYOK AI endpoint (constitution IX) -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name=".CircleSearchApplication"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:theme="@style/Theme.CircleSearch">

        <activity
            android:name=".data.capture.MediaProjectionConsentActivity"
            android:exported="false"
            android:theme="@style/Theme.CircleSearch.Transparent" />

        <!--
          Still to add: TriggerEntryActivity/MainActivity/
          ScreenCaptureForegroundService/TriggerAccessibilityService, by T022, T064,
          T028, T062 respectively.
        -->

    </application>

</manifest>
